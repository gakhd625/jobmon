# ============================================================
# OnlineJobsPH Credentials
# ============================================================
OJPH_EMAIL=your_email@example.com
OJPH_PASSWORD=your_password_here

# ============================================================
# Telegram Bot Settings
# Create a bot via @BotFather on Telegram, get the token.
# Add bot to your group, then get the chat ID.
# ============================================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=-1001234567890

# ============================================================
# OpenAI API Key (optional – only used for LLM scoring)
# Leave blank to skip LLM scoring entirely.
# ============================================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# App Behavior (optional overrides)
# ============================================================
# How many newest jobs to scrape per run (default: 5)
SCRAPE_LIMIT=5

# Minimum LLM score to send a Telegram alert (default: 6)
LLM_SCORE_THRESHOLD=6

# Set to "false" to disable LLM scoring entirely (default: true)
ENABLE_LLM=true
